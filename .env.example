# Copy this file to .env and fill in the real values for this machine.
# Nothing in the source code is hardcoded — every host/IP/port/credential
# the app needs comes from these variables.

# Demo mode: when "true", every page runs entirely on deterministic mock
# data and local looping video clips (see public/videos/) — no backend
# vars below are read or required. Set this in Vercel's project env vars
# for a backend-free demo deploy; leave "false"/unset for a real deployment.
NEXT_PUBLIC_DEMO_MODE=false

# Secret used to sign the login session cookie (src/lib/auth.ts, src/proxy.ts).
# Server only, never exposed to the browser. Generate a random value per
# machine, e.g. `openssl rand -hex 32`.
AUTH_COOKIE_SECRET=change_me

# AI / analytics (detection) backend — safe for browser use
NEXT_PUBLIC_API_BASE=http://<DETECTION_API_HOST>:18088
NEXT_PUBLIC_POLL_INTERVAL=5000

# Camera list API — server only, never exposed to the browser
STREAMS_API_URL=http://<STREAMS_API_HOST>:8000/api/streams/list
STREAMS_API_USERNAME=admin
STREAMS_API_PASSWORD=change_me

# Live camera feed proxy — server only, never exposed to the browser
CAMERA_FEED_BASE_URL=http://<CAMERA_FEED_HOST>:8889
CAMERA_FEED_USERNAME=admin
CAMERA_FEED_PASSWORD=change_me
